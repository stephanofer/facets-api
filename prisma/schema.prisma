generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String       @id @default(cuid(2))
  email           String       @unique
  password        String
  firstName       String
  lastName        String
  emailVerified   Boolean      @default(false)
  emailVerifiedAt DateTime?
  status          UserStatus   @default(PENDING_VERIFICATION)
  platformRole    PlatformRole @default(USER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  refreshTokens          RefreshToken[]
  otpCodes               OtpCode[]
  profile                UserProfile?
  memberships            WorkspaceMembership[]   @relation("WorkspaceMembershipUser")
  invitedMemberships     WorkspaceMembership[]   @relation("WorkspaceMembershipInviter")
  requestedPlanChanges   PlanChangeLog[]         @relation("PlanChangeRequestedBy")
  uploadedFiles          File[]                  @relation("UploadedFiles")
  createdTransactions    Transaction[]           @relation("TransactionCreatedBy")
  createdReconciliations AccountReconciliation[] @relation("AccountReconciliationCreatedBy")

  @@index([email])
  @@index([status])
  @@map("users")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

model RefreshToken {
  id        String    @id @default(cuid(2))
  token     String    @unique // hashed
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OtpCode {
  id          String    @id @default(cuid(2))
  code        String // SHA-256 hashed 6-digit OTP
  type        OtpType
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, type, usedAt, expiresAt])
  @@index([expiresAt])
  @@map("otp_codes")
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// =============================================================================
// WORKSPACE-FIRST TENANCY FOUNDATION
// =============================================================================

/// Workspace is the tenant boundary for business data, billing, and feature access.
/// This baseline is intentionally destructive versus the legacy user-owned model.
/// When the user applies migrations manually, local/test databases should be reset
/// to this new truth instead of preserving fake backwards compatibility.
model Workspace {
  id                     String          @id @default(cuid(2))
  name                   String          @db.VarChar(120)
  slug                   String?         @unique @db.VarChar(120)
  type                   WorkspaceType   @default(PERSONAL)
  status                 WorkspaceStatus @default(ACTIVE)
  financialDataUpdatedAt DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        WorkspaceMembership[]
  settings           WorkspaceSettings?
  // Prisma cannot enforce requiredness on the back side of a 1:1 relation.
  // Backend must create one subscription row per workspace from day 0.
  // Free workspaces also get a subscription row pointing to the Free plan.
  subscription       Subscription?
  usageEvents        UsageEvent[]
  usageRecords       UsageRecord[]
  planChangeLogs     PlanChangeLog[]
  files              File[]
  accounts           Account[]
  categories         Category[]
  workspaceMerchants WorkspaceMerchant[]
  tags               Tag[]
  transactions       Transaction[]
  transfers          Transfer[]
  budgets            Budget[]
  recurringReminders RecurringReminder[]

  @@index([status])
  @@index([type, status])
  @@map("workspaces")
}

/// Membership joins identity to tenant context. Role and status live HERE, not on User.
/// There is exactly ONE canonical membership row per workspace-user pair.
/// Status mutates over time on that row instead of creating duplicate rows for invite/remove/rejoin.
model WorkspaceMembership {
  id              String                    @id @default(cuid(2))
  workspaceId     String
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId          String
  user            User                      @relation("WorkspaceMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  role            WorkspaceRole
  status          WorkspaceMembershipStatus @default(ACTIVE)
  invitedAt       DateTime?
  joinedAt        DateTime?
  invitedByUserId String?
  invitedByUser   User?                     @relation("WorkspaceMembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  preference      WorkspaceUserPreference?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([workspaceId, userId], name: "workspace_memberships_workspace_user_unique")
  @@index([workspaceId, status])
  @@index([workspaceId, role, status])
  @@index([userId, status])
  @@index([invitedByUserId])
  @@map("workspace_memberships")
}

/// Shared workspace configuration.
/// This stores tenant-wide defaults and domain rules, NOT personal UI behavior.
model WorkspaceSettings {
  id                String    @id @default(cuid(2))
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  baseCurrencyCode  String    @default("USD") @db.VarChar(3)
  baseCurrency      Currency  @relation(fields: [baseCurrencyCode], references: [code])
  contentLocale     String    @default("en-US") @db.VarChar(10)
  dateFormat        String    @default("DD/MM/YYYY") @db.VarChar(30)
  financialTimezone String    @default("UTC") @db.VarChar(50)
  monthStartDay     Int       @default(1)
  weekStartDay      Int       @default(1)
  displayLabel      String    @db.VarChar(100)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([baseCurrencyCode])
  @@map("workspace_settings")
}

/// Personal preferences scoped to ONE user inside ONE workspace.
/// Typed columns cover stable preferences; JSON buckets cover view-specific UI state.
model WorkspaceUserPreference {
  id                     String              @id @default(cuid(2))
  workspaceId            String
  userId                 String
  membership             WorkspaceMembership @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Cascade)
  uiLocale               String?             @db.VarChar(10)
  theme                  ThemePreference     @default(SYSTEM)
  dateFormat             String?             @db.VarChar(30)
  dashboardPreferences   Json                @default("{}")
  reportPreferences      Json                @default("{}")
  transactionPreferences Json                @default("{}")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_user_preferences")
}

enum ThemePreference {
  SYSTEM
  LIGHT
  DARK
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  GUEST
}

enum WorkspaceMembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum WorkspaceType {
  PERSONAL
  FAMILY
  GROUP
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model Plan {
  id            String   @id @default(cuid(2))
  code          String   @unique
  name          String
  description   String?
  priceMonthly  Decimal  @db.Decimal(10, 2)
  priceCurrency String   @default("USD") @db.VarChar(3)
  priceYearly   Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions  Subscription[]
  planFeatures   PlanFeature[]
  fromChangeLogs PlanChangeLog[] @relation("FromPlan")
  toChangeLogs   PlanChangeLog[] @relation("ToPlan")

  @@index([code])
  @@index([isActive, sortOrder])
  @@map("plans")
}

/// Canonical catalog of billable/gated features.
/// This avoids string drift across plans, usage events, and usage rollups.
model FeatureDefinition {
  code               String           @id @db.VarChar(100)
  name               String           @db.VarChar(120)
  description        String?
  featureType        FeatureType
  defaultLimitType   FeatureLimitType @default(BOOLEAN)
  defaultLimitPeriod LimitPeriod?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  planFeatures PlanFeature[]
  usageEvents  UsageEvent[]
  usageRecords UsageRecord[]

  @@index([isActive, featureType])
  @@map("feature_definitions")
}

model Subscription {
  id                     String             @id @default(cuid(2))
  workspaceId            String             @unique
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planId                 String
  plan                   Plan               @relation(fields: [planId], references: [id])
  planCodeSnapshot       String             @db.VarChar(100)
  planNameSnapshot       String             @db.VarChar(120)
  billingInterval        BillingInterval?
  billingAmount          Decimal            @default(0) @db.Decimal(10, 2)
  billingCurrency        String             @default("USD") @db.VarChar(3)
  providerCustomerId     String?            @db.VarChar(191)
  providerSubscriptionId String?            @unique @db.VarChar(191)
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime           @default(now())
  currentPeriodEnd       DateTime? // null for free plan or while no paid cycle exists yet

  trialStart DateTime?
  trialEnd   DateTime?

  cancelledAt  DateTime?
  cancelReason String?

  graceOverages  Json?
  gracePeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([planId])
  @@index([status])
  @@index([status, currentPeriodEnd])
  @@index([status, gracePeriodEnd])
  @@map("subscriptions")
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

model PlanChangeLog {
  id                          String              @id @default(cuid(2))
  workspaceId                 String
  workspace                   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedByUserId           String?
  requestedByUser             User?               @relation("PlanChangeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  fromPlanId                  String?
  fromPlan                    Plan?               @relation("FromPlan", fields: [fromPlanId], references: [id])
  fromPlanCodeSnapshot        String?             @db.VarChar(100)
  toPlanId                    String?
  toPlan                      Plan?               @relation("ToPlan", fields: [toPlanId], references: [id])
  toPlanCodeSnapshot          String?             @db.VarChar(100)
  changeType                  PlanChangeType
  status                      PlanChangeStatus    @default(REQUESTED)
  source                      PlanChangeSource    @default(USER)
  billingInterval             BillingInterval?
  billingAmount               Decimal?            @db.Decimal(10, 2)
  billingCurrency             String?             @db.VarChar(3)
  requestedAt                 DateTime            @default(now())
  effectiveAt                 DateTime?
  scheduledFor                DateTime?
  prorationAmount             Decimal?            @db.Decimal(10, 2)
  resultingSubscriptionStatus SubscriptionStatus?
  reason                      String?
  metadata                    Json?
  createdAt                   DateTime            @default(now())

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([requestedByUserId])
  @@index([status, scheduledFor])
  @@map("plan_change_logs")
}

enum PlanChangeType {
  UPGRADE
  DOWNGRADE
  CANCELLATION
  REACTIVATION
}

enum PlanChangeStatus {
  REQUESTED
  SCHEDULED
  APPLIED
  CANCELLED
  FAILED
}

enum PlanChangeSource {
  USER
  ADMIN
  SYSTEM
}

model PlanFeature {
  id           String            @id @default(cuid(2))
  planId       String
  plan         Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureCode  String            @db.VarChar(100)
  feature      FeatureDefinition @relation(fields: [featureCode], references: [code], onDelete: Restrict)
  limitType    FeatureLimitType  @default(BOOLEAN)
  limitValue   Int               @default(1)
  limitPeriod  LimitPeriod?
  overrideType FeatureType?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([planId, featureCode])
  @@index([featureCode])
  @@map("plan_features")
}

enum FeatureLimitType {
  BOOLEAN // on/off
  COUNT // numeric limit
  UNLIMITED // no limit
}

enum FeatureType {
  RESOURCE // Count from actual table (accounts, goals) - deletable
  CONSUMABLE // Count from UsageEvent + UsageRecord rollups - period-based
}

enum LimitPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum UsageEventSource {
  APP
  IMPORT
  SYSTEM
  BACKFILL
}

/// Append-only source of truth for metered usage.
/// Retries should reuse the same `idempotencyKey` within the same workspace
/// so the same logical operation is only recorded once.
model UsageEvent {
  id             String            @id @default(cuid(2))
  workspaceId    String
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureCode    String            @db.VarChar(100)
  feature        FeatureDefinition @relation(fields: [featureCode], references: [code], onDelete: Restrict)
  quantity       Int               @default(1)
  source         UsageEventSource  @default(APP)
  idempotencyKey String?           @db.VarChar(191)
  occurredAt     DateTime          @default(now())
  metadata       Json?
  createdAt      DateTime          @default(now())

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, featureCode, occurredAt])
  @@index([workspaceId, source, occurredAt])
  @@map("usage_events")
}

/// Period rollup derived from usage events for consumable features.
/// Resource-style features should prefer counting from their source tables directly.
model UsageRecord {
  id          String            @id @default(cuid(2))
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureCode String            @db.VarChar(100)
  feature     FeatureDefinition @relation(fields: [featureCode], references: [code], onDelete: Restrict)
  periodType  LimitPeriod
  periodStart DateTime
  periodEnd   DateTime
  count       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([workspaceId, featureCode, periodType, periodStart])
  @@index([workspaceId, featureCode, periodType, periodEnd])
  @@index([periodEnd])
  @@map("usage_records")
}

// -----------------------------------------------------------------------------
// Reference Tables (low-cardinality, high-read → cacheable)
// -----------------------------------------------------------------------------

/// ISO 4217 currency reference table.
/// Seeded with ~30 most common currencies. Extensible via INSERT (no migration needed).
/// This is the SINGLE SOURCE OF TRUTH for currencies across the entire app.
model Currency {
  code         String  @id @db.VarChar(3) // ISO 4217: USD, EUR, ARS, etc.
  name         String  @db.VarChar(100) // "US Dollar", "Euro", "Argentine Peso"
  symbol       String  @db.VarChar(10) // "$", "€", "$"
  decimalScale Int     @default(2) // Most currencies have 2 decimal places, JPY has 0, BHD has 3
  isActive     Boolean @default(true)

  userProfiles         UserProfile[]
  workspaceSettings    WorkspaceSettings[]
  accounts             Account[]
  accountDailyBalances AccountDailyBalance[]
  transactions         Transaction[]
  budgets              Budget[]
  recurringReminders   RecurringReminder[]
  exchangeRatesFrom    ExchangeRate[]        @relation("ExchangeRateFrom")
  exchangeRatesTo      ExchangeRate[]        @relation("ExchangeRateTo")
  countries            Country[]

  @@index([isActive])
  @@map("currencies")
}

/// ISO 3166-1 country reference table.
/// Seeded with ~50 most common countries. Extensible via INSERT.
/// Used for user localization, tax rules (future), and regional features.
model Country {
  code         String   @id @db.VarChar(2) // ISO 3166-1 alpha-2: US, AR, BR, etc.
  name         String   @db.VarChar(100) // "United States", "Argentina", "Brazil"
  currencyCode String   @db.VarChar(3) // Default currency for this country
  currency     Currency @relation(fields: [currencyCode], references: [code])
  phoneCode    String   @db.VarChar(10) // "+1", "+54", "+55"
  locale       String   @default("en-US") @db.VarChar(10) // BCP 47 locale tag
  isActive     Boolean  @default(true)

  userProfiles UserProfile[]

  @@index([isActive])
  @@index([currencyCode])
  @@map("countries")
}

// -----------------------------------------------------------------------------
// User Profile (1:1 with User — separated from auth for performance)
// -----------------------------------------------------------------------------

/// Extended user information collected during/after onboarding.
/// Separated from User to keep auth queries FAST (User table only has auth fields).
///
/// WHY 1:1 instead of columns on User?
/// - User table is hit on EVERY authenticated request (JWT validation → findById)
/// - Profile data is only needed in profile/settings screens
/// - Keeps the auth hot path lean and fast
model UserProfile {
  id     String @id @default(cuid(2))
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal details
  phone            String? @db.VarChar(20) // E.164 format: +5491155557777
  avatarUrl        String? @db.VarChar(500)
  avatarStorageKey String? @db.VarChar(500)

  // Profile context
  countryCode String?  @db.VarChar(2)
  country     Country? @relation(fields: [countryCode], references: [code])

  // Onboarding
  onboardingCompletedAt DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  currency     Currency? @relation(fields: [currencyCode], references: [code])
  currencyCode String?   @db.VarChar(3)

  @@index([countryCode])
  @@map("user_profiles")
}

// =============================================================================
// PHASE 13: File Storage
// =============================================================================

enum FilePurpose {
  ATTACHMENT
  // Agregar futuros propósitos acá
}

/// Source of truth for all files stored in R2 (Cloudflare Object Storage).
///
/// DESIGN DECISIONS:
/// - Every file uploaded lives exactly once in this table, regardless of context
///   (avatar, receipt, etc.). Context is determined by `purpose`.
/// - `bucket` + `key` together are unique. This prevents the same physical file
///   from being registered twice. Also enables idempotent cleanup operations.
/// - `publicUrl` is only set for files in the public bucket. Private files use
///   presigned URLs generated on-demand (not stored here because they expire).
/// - Soft delete (`deletedAt`) allows recovery and defers actual R2 deletion
///   to a background cron job, avoiding coupling HTTP requests to external calls.
/// - `workspaceId` is required on every file for tenant scoping and ownership checks.
///
/// CONTEXT RELATIONS:
/// - Reserved for future workspace-owned file attachments (receipts, statements, etc.)
model File {
  id               String    @id @default(cuid(2))
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedByUserId String?
  uploadedByUser   User?     @relation("UploadedFiles", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  purpose      FilePurpose
  bucket       String      @db.VarChar(100) // "facets-public" | "facets-private"
  key          String      @db.VarChar(500) // path en R2: "avatars/<uuid>.webp"
  mimeType     String      @db.VarChar(100) // detectado por magic bytes en el servidor
  size         Int // tamaño en bytes
  originalName String      @db.VarChar(255) // nombre original del cliente (solo display)

  publicUrl String? @db.VarChar(500) // solo si bucket público; NULL para privados

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete — R2 cleanup via cron job

  @@unique([bucket, key])
  @@index([workspaceId])
  @@index([workspaceId, purpose])
  @@index([uploadedByUserId])
  @@index([deletedAt])
  @@map("files")
}

// =============================================================================
// PHASE 14: Financial Core (Cashflow-first MVP)
// =============================================================================

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  DEBT
  LOAN
  LENT_MONEY
}

enum AccountStatus {
  ACTIVE
  ARCHIVED
}

enum LentMoneyStatus {
  OPEN
  SETTLED
  FORGIVEN
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum TransactionDirection {
  INFLOW
  OUTFLOW
}

enum TransactionKind {
  STANDARD
  FUNDS_MOVEMENT
  CC_PAYMENT
  LOAN_PAYMENT
  DEBT_PAYMENT
  ONE_TIME
}

enum BudgetStatus {
  ACTIVE
  ARCHIVED
}

enum ReminderAmountType {
  FIXED
  RANGE
}

model Account {
  id                   String        @id @default(cuid(2))
  workspaceId          String
  workspace            Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                 String        @db.VarChar(120)
  type                 AccountType
  currencyCode         String        @db.VarChar(3)
  currency             Currency      @relation(fields: [currencyCode], references: [code])
  initialBalance       Decimal       @default(0) @db.Decimal(19, 4)
  currentBalanceCached Decimal       @default(0) @db.Decimal(19, 4)
  status               AccountStatus @default(ACTIVE)
  includeInReports     Boolean       @default(true)
  notes                String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  loanProfile       LoanProfile?
  creditCardProfile CreditCardProfile?
  debtProfile       DebtProfile?
  lentMoneyProfile  LentMoneyProfile?
  transactions      Transaction[]
  reconciliations   AccountReconciliation[]
  dailyBalances     AccountDailyBalance[]

  @@unique([workspaceId, id])
  @@index([workspaceId, type, status])
  @@index([workspaceId, includeInReports])
  @@index([workspaceId, currencyCode])
  @@map("accounts")
}

model AccountDailyBalance {
  id                String   @id @default(cuid(2))
  accountId         String
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date              DateTime @db.Date
  currencyCode      String   @db.VarChar(3)
  currency          Currency @relation(fields: [currencyCode], references: [code])
  openingBalance    Decimal  @default(0) @db.Decimal(19, 4)
  inflowsAmount     Decimal  @default(0) @db.Decimal(19, 4)
  outflowsAmount    Decimal  @default(0) @db.Decimal(19, 4)
  adjustmentsAmount Decimal  @default(0) @db.Decimal(19, 4)
  closingBalance    Decimal  @default(0) @db.Decimal(19, 4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, date])
  @@index([accountId, date])
  @@index([date])
  @@map("account_daily_balances")
}

model LoanProfile {
  id                         String    @id @default(cuid(2))
  accountId                  String    @unique
  account                    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lenderName                 String?   @db.VarChar(120)
  interestRate               Decimal?  @db.Decimal(8, 4)
  estimatedInstallmentAmount Decimal?  @db.Decimal(19, 4)
  termMonths                 Int?
  dueDayOfMonth              Int?
  startedAt                  DateTime? @db.Date
  maturityDate               DateTime? @db.Date
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@map("loan_profiles")
}

model CreditCardProfile {
  id                String   @id @default(cuid(2))
  accountId         String   @unique
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  issuerName        String?  @db.VarChar(120)
  last4             String?  @db.VarChar(4)
  creditLimit       Decimal? @db.Decimal(19, 4)
  closingDayOfMonth Int?
  dueDayOfMonth     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("credit_card_profiles")
}

model DebtProfile {
  id           String    @id @default(cuid(2))
  accountId    String    @unique
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  creditorName String?   @db.VarChar(120)
  dueDate      DateTime? @db.Date
  reference    String?   @db.VarChar(120)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("debt_profiles")
}

model LentMoneyProfile {
  id                    String          @id @default(cuid(2))
  accountId             String          @unique
  account               Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  borrowerName          String?         @db.VarChar(120)
  expectedRepaymentDate DateTime?       @db.Date
  status                LentMoneyStatus @default(OPEN)
  notes                 String?         @db.Text
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("lent_money_profiles")
}

model AccountReconciliation {
  id              String   @id @default(cuid(2))
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  createdByUserId String?
  createdByUser   User?    @relation("AccountReconciliationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  date            DateTime @db.Date
  targetBalance   Decimal  @db.Decimal(19, 4)
  reason          String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([accountId, date, createdAt])
  @@index([createdByUserId])
  @@map("account_reconciliations")
}

model Category {
  id          String       @id @default(cuid(2))
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Category?    @relation("CategoryHierarchy", fields: [workspaceId, parentId], references: [workspaceId, id], onDelete: Restrict)
  children    Category[]   @relation("CategoryHierarchy")
  kind        CategoryKind
  key         String?      @db.VarChar(100)
  name        String       @db.VarChar(120)
  color       String?      @db.VarChar(20)
  icon        String?      @db.VarChar(100)
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  transactions       Transaction[]
  budgetLines        BudgetLine[]
  recurringReminders RecurringReminder[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, key])
  @@unique([workspaceId, parentId, name, kind])
  @@index([workspaceId, kind, isActive])
  @@map("categories")
}

model SystemMerchant {
  id                   String   @id @default(cuid(2))
  name                 String   @db.VarChar(160)
  normalizedName       String   @db.VarChar(160)
  logoUrl              String?  @db.VarChar(500)
  suggestedCategoryKey String?  @db.VarChar(100)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  transactions Transaction[]

  @@unique([normalizedName])
  @@index([isActive])
  @@map("system_merchants")
}

model WorkspaceMerchant {
  id             String    @id @default(cuid(2))
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String    @db.VarChar(160)
  normalizedName String    @db.VarChar(160)
  logoUrl        String?   @db.VarChar(500)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions Transaction[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, isActive])
  @@map("workspace_merchants")
}

model Tag {
  id             String    @id @default(cuid(2))
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String    @db.VarChar(80)
  normalizedName String    @db.VarChar(80)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions TransactionTag[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, normalizedName])
  @@index([workspaceId])
  @@map("tags")
}

model Transaction {
  id                    String               @id @default(cuid(2))
  workspaceId           String
  workspace             Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId             String
  account               Account              @relation(fields: [workspaceId, accountId], references: [workspaceId, id], onDelete: Restrict)
  date                  DateTime             @db.Date
  amount                Decimal              @db.Decimal(19, 4)
  direction             TransactionDirection
  currencyCode          String               @db.VarChar(3)
  currency              Currency             @relation(fields: [currencyCode], references: [code])
  description           String               @db.VarChar(255)
  kind                  TransactionKind      @default(STANDARD)
  categoryId            String?
  category              Category?            @relation(fields: [workspaceId, categoryId], references: [workspaceId, id], onDelete: Restrict)
  systemMerchantId      String?
  systemMerchant        SystemMerchant?      @relation(fields: [systemMerchantId], references: [id], onDelete: SetNull)
  workspaceMerchantId   String?
  workspaceMerchant     WorkspaceMerchant?   @relation(fields: [workspaceId, workspaceMerchantId], references: [workspaceId, id], onDelete: Restrict)
  notes                 String?              @db.Text
  isExcludedFromReports Boolean              @default(false)
  sourceProvider        String?              @db.VarChar(50)
  sourceExternalId      String?              @db.VarChar(191)
  sourceDedupKey        String?              @db.VarChar(255)
  createdByUserId       String?
  createdByUser         User?                @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  outgoingTransfer Transfer?        @relation("TransferFromTransaction")
  incomingTransfer Transfer?        @relation("TransferToTransaction")
  tags             TransactionTag[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, sourceDedupKey])
  @@unique([workspaceId, sourceProvider, sourceExternalId])
  @@index([workspaceId, date])
  @@index([accountId, date])
  @@index([workspaceId, date, direction])
  @@index([workspaceId, date, kind])
  @@index([systemMerchantId])
  @@index([workspaceId, workspaceMerchantId])
  @@index([workspaceId, sourceProvider])
  @@map("transactions")
}

model TransactionTag {
  id            String      @id @default(cuid(2))
  workspaceId   String
  transactionId String
  transaction   Transaction @relation(fields: [workspaceId, transactionId], references: [workspaceId, id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [workspaceId, tagId], references: [workspaceId, id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([transactionId, tagId])
  @@index([workspaceId])
  @@index([tagId])
  @@map("transaction_tags")
}

model Transfer {
  id                String      @id @default(cuid(2))
  workspaceId       String
  workspace         Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromTransactionId String
  fromTransaction   Transaction @relation("TransferFromTransaction", fields: [workspaceId, fromTransactionId], references: [workspaceId, id], onDelete: Restrict)
  toTransactionId   String
  toTransaction     Transaction @relation("TransferToTransaction", fields: [workspaceId, toTransactionId], references: [workspaceId, id], onDelete: Restrict)
  fxRateUsed        Decimal?    @db.Decimal(20, 10)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([workspaceId, fromTransactionId])
  @@unique([workspaceId, toTransactionId])
  @@index([workspaceId])
  @@map("transfers")
}

model ExchangeRate {
  id               String   @id @default(cuid(2))
  fromCurrencyCode String   @db.VarChar(3)
  fromCurrency     Currency @relation("ExchangeRateFrom", fields: [fromCurrencyCode], references: [code])
  toCurrencyCode   String   @db.VarChar(3)
  toCurrency       Currency @relation("ExchangeRateTo", fields: [toCurrencyCode], references: [code])
  date             DateTime @db.Date
  rate             Decimal  @db.Decimal(20, 10)
  source           String?  @db.VarChar(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([fromCurrencyCode, toCurrencyCode, date])
  @@index([fromCurrencyCode, toCurrencyCode])
  @@map("exchange_rates")
}

model Budget {
  id           String       @id @default(cuid(2))
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  currencyCode String       @db.VarChar(3)
  currency     Currency     @relation(fields: [currencyCode], references: [code])
  periodStart  DateTime     @db.Date
  periodEnd    DateTime     @db.Date
  status       BudgetStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lines BudgetLine[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, periodStart, periodEnd])
  @@index([workspaceId, periodStart])
  @@map("budgets")
}

model BudgetLine {
  id          String   @id @default(cuid(2))
  workspaceId String
  budgetId    String
  budget      Budget   @relation(fields: [workspaceId, budgetId], references: [workspaceId, id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [workspaceId, categoryId], references: [workspaceId, id], onDelete: Restrict)
  amount      Decimal  @db.Decimal(19, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([budgetId, categoryId])
  @@index([workspaceId, categoryId])
  @@map("budget_lines")
}

model RecurringReminder {
  id                 String               @id @default(cuid(2))
  workspaceId        String
  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String               @db.VarChar(120)
  direction          TransactionDirection
  expectedDayOfMonth Int
  amountType         ReminderAmountType
  amount             Decimal?             @db.Decimal(19, 4)
  amountMin          Decimal?             @db.Decimal(19, 4)
  amountMax          Decimal?             @db.Decimal(19, 4)
  currencyCode       String               @db.VarChar(3)
  currency           Currency             @relation(fields: [currencyCode], references: [code])
  categoryId         String?
  category           Category?            @relation(fields: [workspaceId, categoryId], references: [workspaceId, id], onDelete: Restrict)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([workspaceId, isActive])
  @@index([workspaceId, expectedDayOfMonth])
  @@map("recurring_reminders")
}
